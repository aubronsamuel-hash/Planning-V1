# ─────────────────────────────────────────────────────────
# Sentry — Error tracking & performance monitoring
# https://sentry.io → Settings > Projects > [project] > Client Keys (DSN)
# ─────────────────────────────────────────────────────────
# DSN public (exposé côté client via NEXT_PUBLIC_*)
NEXT_PUBLIC_SENTRY_DSN="https://xxxx@oXXXX.ingest.sentry.io/XXXXXX"
# DSN serveur (identique mais non exposé)
SENTRY_DSN="https://xxxx@oXXXX.ingest.sentry.io/XXXXXX"
# Auth token pour upload des source maps (CI uniquement)
SENTRY_AUTH_TOKEN="sntrys_xxxxxxxxxxxxxxxxxxxx"
# Identifiants du projet Sentry (pour le CLI sentry-cli)
SENTRY_ORG="votre-organisation"
SENTRY_PROJECT="saas-spectacle-vivant"

# ─────────────────────────────────────────────────────────
# Logtail / Better Stack — Logs structurés
# https://betterstack.com/logtail → Sources > [source] > Source Token
# Optionnel : si absent, les logs restent sur stdout uniquement
# ─────────────────────────────────────────────────────────
LOGTAIL_SOURCE_TOKEN="xxxxxxxxxxxxxxxxxxxx"
